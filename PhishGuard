<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PhishGuard — Website Safety Checker</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #08080d;
    --surface: #111118;
    --surface2: #191921;
    --border: rgba(255,255,255,0.06);
    --border2: rgba(255,255,255,0.11);
    --text: #eaeaf2;
    --muted: #64647a;
    --accent: #00e5a0;
    --accent-dim: rgba(0,229,160,0.1);
    --danger: #ff4757;
    --danger-dim: rgba(255,71,87,0.1);
    --warn: #ffa502;
    --warn-dim: rgba(255,165,2,0.1);
    --safe: #00e5a0;
    --safe-dim: rgba(0,229,160,0.09);
    --mono: 'Space Mono', monospace;
    --display: 'Syne', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--display);
    min-height: 100vh;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(0,229,160,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,160,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none; z-index: 0;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 48px;
    background: rgba(8,8,13,0.9);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
  }
  .logo {
    font-family: var(--mono); font-size: 14px; font-weight: 700;
    color: var(--accent); letter-spacing: 0.06em;
    display: flex; align-items: center; gap: 10px;
  }
  .logo-icon {
    width: 30px; height: 30px;
    background: var(--accent-dim);
    border: 1px solid rgba(0,229,160,0.25);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .logo-icon svg { width: 15px; height: 15px; }
  .nav-right { display: flex; align-items: center; gap: 10px; }
  .nav-badge {
    font-family: var(--mono); font-size: 11px;
    color: var(--muted); background: var(--surface);
    border: 1px solid var(--border2); border-radius: 20px; padding: 4px 14px;
  }
  .nav-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px rgba(0,229,160,0.6);
    animation: blink 2.5s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* HERO */
  .hero {
    position: relative; z-index: 1;
    text-align: center; padding: 110px 40px 84px;
  }
  .hero-glow {
    position: absolute; top: -40px; left: 50%; transform: translateX(-50%);
    width: 800px; height: 420px;
    background: radial-gradient(ellipse at 50% 38%, rgba(0,229,160,0.09) 0%, transparent 62%);
    pointer-events: none; z-index: -1;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: 10px; color: var(--accent);
    background: rgba(0,229,160,0.07);
    border: 1px solid rgba(0,229,160,0.16);
    border-radius: 20px; padding: 6px 16px;
    margin-bottom: 38px; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .tag-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); animation: blink 2s ease-in-out infinite; }
  h1 {
    font-size: clamp(46px, 8vw, 88px);
    font-weight: 800; line-height: 1.0;
    letter-spacing: -0.035em;
    margin-bottom: 26px; color: #fff;
  }
  h1 em {
    font-style: normal; color: var(--accent);
    position: relative; display: inline-block;
  }
  h1 em::after { display: none; }
  .hero-sub {
    font-size: 15px; color: var(--muted);
    max-width: 390px; margin: 0 auto 58px;
    line-height: 1.8; font-weight: 400;
  }

  /* INPUT */
  .input-wrap { max-width: 700px; margin: 0 auto; }
  .url-field {
    display: flex; align-items: center;
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 18px;
    padding: 8px 8px 8px 22px; gap: 12px;
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .url-field:focus-within {
    border-color: rgba(0,229,160,0.42);
    box-shadow: 0 0 0 5px rgba(0,229,160,0.06), 0 16px 48px rgba(0,0,0,0.55);
  }
  .url-icon { color: var(--muted); display: flex; flex-shrink: 0; }
  .url-icon svg { width: 15px; height: 15px; }
  #url-input {
    flex: 1; background: none; border: none; outline: none;
    font-family: var(--mono); font-size: 14px;
    color: var(--text); padding: 11px 0; min-width: 0;
    letter-spacing: 0.01em;
  }
  #url-input::placeholder { color: var(--muted); }
  .check-btn {
    flex-shrink: 0; background: var(--accent); color: #000;
    border: none; border-radius: 12px; padding: 13px 26px;
    font-family: var(--display); font-size: 14px; font-weight: 700;
    cursor: pointer; transition: all 0.15s; white-space: nowrap;
    letter-spacing: 0.02em; display: flex; align-items: center; gap: 8px;
  }
  .check-btn svg { width: 14px; height: 14px; transition: transform 0.2s; }
  .check-btn:hover { background: #00ffb3; transform: translateY(-1px); box-shadow: 0 8px 28px rgba(0,229,160,0.28); }
  .check-btn:hover svg { transform: translateX(3px); }
  .check-btn:active { transform: scale(0.98); }

  /* RESULT */
  #result-section {
    max-width: 780px; margin: 0 auto;
    padding: 0 40px 100px;
    position: relative; z-index: 1;
    display: none;
  }
  #result-section.visible { display: block; animation: fade-up 0.5s cubic-bezier(0.16,1,0.3,1); }
  @keyframes fade-up { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

  /* VERDICT */
  .verdict-card {
    border-radius: 22px; padding: 34px 38px;
    margin-bottom: 26px; border: 1px solid;
    position: relative; overflow: hidden;
  }
  .verdict-card::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
  }
  .verdict-card::after {
    content: ''; position: absolute;
    top: -80px; right: -80px;
    width: 240px; height: 240px; border-radius: 50%;
    opacity: 0.04; pointer-events: none;
  }
  .verdict-card.safe { background: rgba(0,229,160,0.035); border-color: rgba(0,229,160,0.18); }
  .verdict-card.safe::before { background: linear-gradient(90deg,transparent,var(--safe) 40%,transparent); }
  .verdict-card.safe::after { background: var(--safe); }
  .verdict-card.danger { background: rgba(255,71,87,0.035); border-color: rgba(255,71,87,0.18); }
  .verdict-card.danger::before { background: linear-gradient(90deg,transparent,var(--danger) 40%,transparent); }
  .verdict-card.danger::after { background: var(--danger); }
  .verdict-card.warning { background: rgba(255,165,2,0.035); border-color: rgba(255,165,2,0.18); }
  .verdict-card.warning::before { background: linear-gradient(90deg,transparent,var(--warn) 40%,transparent); }
  .verdict-card.warning::after { background: var(--warn); }

  .verdict-top { display: flex; align-items: flex-start; gap: 22px; }
  .verdict-icon {
    width: 58px; height: 58px; border-radius: 15px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 26px; font-weight: 700;
    font-family: var(--mono);
  }
  .verdict-card.safe .verdict-icon { background: rgba(0,229,160,0.12); color: var(--safe); }
  .verdict-card.danger .verdict-icon { background: rgba(255,71,87,0.12); color: var(--danger); }
  .verdict-card.warning .verdict-icon { background: rgba(255,165,2,0.12); color: var(--warn); }
  .verdict-label {
    font-family: var(--mono); font-size: 10px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 8px;
  }
  .verdict-card.safe .verdict-label { color: var(--safe); }
  .verdict-card.danger .verdict-label { color: var(--danger); }
  .verdict-card.warning .verdict-label { color: var(--warn); }
  .verdict-title { font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 8px; line-height: 1.25; }
  .verdict-url { font-family: var(--mono); font-size: 12px; color: var(--muted); word-break: break-all; line-height: 1.5; }
  .risk-score {
    display: flex; align-items: center; gap: 16px;
    margin-top: 26px; padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .risk-label { font-size: 10px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap; }
  .risk-track { flex: 1; height: 5px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; }
  .risk-fill { height: 100%; border-radius: 3px; transition: width 1.3s cubic-bezier(0.16,1,0.3,1); width: 0; }
  .risk-num { font-family: var(--mono); font-size: 15px; font-weight: 700; min-width: 50px; text-align: right; }
  .risk-num span { font-size: 10px; opacity: 0.45; }

  /* SECTION LABEL */
  .section-label {
    font-size: 10px; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 14px; display: flex; align-items: center; gap: 12px;
  }
  .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* SIGNALS */
  .signals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 10px; margin-bottom: 26px;
  }
  .signal-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 16px 18px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .signal-card:hover { border-color: var(--border2); transform: translateY(-2px); }
  .signal-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 9px; }
  .signal-name { font-size: 10px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .signal-badge {
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    padding: 2px 8px; border-radius: 4px;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .badge-safe { background: var(--safe-dim); color: var(--safe); border: 1px solid rgba(0,229,160,0.16); }
  .badge-danger { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(255,71,87,0.16); }
  .badge-warn { background: var(--warn-dim); color: var(--warn); border: 1px solid rgba(255,165,2,0.16); }
  .badge-neutral { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }
  .signal-value { font-size: 13px; color: var(--text); font-weight: 600; word-break: break-all; line-height: 1.4; margin-bottom: 4px; }
  .signal-detail { font-size: 11px; color: var(--muted); line-height: 1.5; }

  /* FLAGS */
  .flags-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 18px; padding: 28px 30px; margin-bottom: 20px;
  }
  .flag-item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 13px 0; border-bottom: 1px solid var(--border);
  }
  .flag-item:last-child { border-bottom: none; padding-bottom: 0; }
  .flag-item:first-child { padding-top: 0; }
  .flag-dot {
    width: 7px; height: 7px; border-radius: 50%;
    flex-shrink: 0; margin-top: 6px;
  }
  .flag-dot.red { background: var(--danger); box-shadow: 0 0 8px rgba(255,71,87,0.5); }
  .flag-dot.yellow { background: var(--warn); box-shadow: 0 0 8px rgba(255,165,2,0.5); }
  .flag-dot.green { background: var(--safe); box-shadow: 0 0 8px rgba(0,229,160,0.5); }
  .flag-text { font-size: 14px; color: var(--text); flex: 1; line-height: 1.5; font-weight: 500; }
  .flag-sub { font-size: 12px; color: var(--muted); margin-top: 3px; line-height: 1.55; }

  /* TIPS */
  .tips-box {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 18px; padding: 28px 30px;
  }
  .tip-row { display: flex; gap: 14px; margin-bottom: 14px; }
  .tip-row:last-child { margin-bottom: 0; }
  .tip-num {
    font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--accent);
    background: var(--accent-dim); border: 1px solid rgba(0,229,160,0.16);
    border-radius: 5px; width: 22px; height: 22px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }
  .tip-text { font-size: 13px; color: var(--muted); line-height: 1.7; }
  .tip-text strong { color: var(--text); }

  /* LOADING */
  .loading-wrap { text-align: center; padding: 72px 0; }
  .scanner-ring {
    width: 50px; height: 50px;
    border: 2px solid rgba(255,255,255,0.05);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.72s linear infinite;
    margin: 0 auto 22px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-size: 12px; color: var(--muted); font-family: var(--mono); margin-bottom: 8px; letter-spacing: 0.04em; }
  .loading-url { font-size: 12px; color: var(--accent); font-family: var(--mono); word-break: break-all; opacity: 0.65; }

  /* HOW IT WORKS */
  .how-section {
    position: relative; z-index: 1;
    padding: 0 40px 100px;
    max-width: 780px; margin: 0 auto;
  }
  .checks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
    gap: 10px;
  }
  .check-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 20px 18px;
    transition: all 0.2s;
  }
  .check-card:hover { border-color: rgba(0,229,160,0.16); transform: translateY(-3px); }
  .check-icon {
    width: 36px; height: 36px; background: var(--accent-dim);
    border-radius: 9px; display: flex; align-items: center;
    justify-content: center; margin-bottom: 13px; font-size: 16px;
  }
  .check-name { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 5px; }
  .check-desc { font-size: 12px; color: var(--muted); line-height: 1.55; }

  /* ERROR */
  .error-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 18px; padding: 44px; text-align: center;
  }
  .error-card .err-icon { font-size: 30px; margin-bottom: 14px; }
  .error-card p { font-size: 14px; color: var(--muted); line-height: 1.7; }
  .error-card code { font-family: var(--mono); color: var(--accent); background: var(--accent-dim); padding: 2px 6px; border-radius: 4px; font-size: 12px; }

  /* DEMO SECTION */
  .demo-section {
    position: relative; z-index: 1;
    padding: 0 40px 100px;
    max-width: 780px; margin: 0 auto;
  }
  .demo-tabs {
    display: flex; gap: 8px; margin-bottom: 20px;
  }
  .demo-tab {
    padding: 8px 20px; border-radius: 10px; cursor: pointer;
    font-size: 13px; font-weight: 600; border: 1px solid;
    transition: all 0.18s; font-family: var(--display);
  }
  .demo-tab.phish { background: var(--danger-dim); border-color: rgba(255,71,87,0.25); color: var(--danger); }
  .demo-tab.real  { background: var(--safe-dim);   border-color: rgba(0,229,160,0.25);  color: var(--safe); }
  .demo-tab:not(.active) { background: var(--surface); border-color: var(--border); color: var(--muted); }
  .demo-tab:hover:not(.active) { border-color: var(--border2); color: var(--text); }

  .demo-panel { display: none; animation: fade-up 0.35s ease; }
  .demo-panel.active { display: block; }

  /* browser chrome */
  .browser-chrome {
    border-radius: 14px; overflow: hidden;
    border: 1px solid var(--border2);
    background: #1a1a24;
  }
  .browser-bar {
    background: #13131e; padding: 10px 16px;
    display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid var(--border);
  }
  .b-dots { display: flex; gap: 6px; }
  .b-dot { width: 10px; height: 10px; border-radius: 50%; }
  .b-url {
    flex: 1; background: #0e0e18; border: 1px solid var(--border2);
    border-radius: 7px; padding: 5px 12px;
    font-family: var(--mono); font-size: 12px;
    display: flex; align-items: center; gap: 8px;
    color: var(--text);
  }
  .b-url .lock { flex-shrink: 0; }
  .b-url-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* site body inside browser */
  .site-body { background: #fff; color: #111; }
  .site-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-bottom: 1px solid #e5e5e5; }
  .site-logo { font-size: 18px; font-weight: 800; letter-spacing: -0.02em; font-family: sans-serif; }
  .site-nav { display: flex; gap: 16px; font-size: 12px; color: #666; font-family: sans-serif; }
  .site-hero { padding: 24px 20px; background: #f7f7f7; border-bottom: 1px solid #e5e5e5; }
  .site-hero h2 { font-size: 16px; font-weight: 700; margin-bottom: 4px; font-family: sans-serif; }
  .site-hero p  { font-size: 12px; color: #666; font-family: sans-serif; line-height: 1.5; }
  .site-form { padding: 20px; }
  .site-form h3 { font-size: 14px; font-weight: 600; margin-bottom: 14px; font-family: sans-serif; }
  .sf { margin-bottom: 10px; }
  .sf label { display: block; font-size: 11px; color: #777; margin-bottom: 3px; font-family: sans-serif; }
  .sf input {
    width: 100%; padding: 7px 10px; border: 1px solid #ddd;
    border-radius: 6px; font-size: 12px; background: #fafafa;
    color: #333; outline: none; font-family: sans-serif;
  }
  .sf-btn {
    width: 100%; padding: 9px; border: none; border-radius: 7px;
    font-size: 13px; font-weight: 700; cursor: default;
    margin-top: 6px; font-family: sans-serif;
  }

  /* annotation callouts */
  .annotations { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
  .ann {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 12px 16px;
  }
  .ann-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
  .ann-dot.r { background: var(--danger); box-shadow: 0 0 8px rgba(255,71,87,0.5); }
  .ann-dot.g { background: var(--safe);   box-shadow: 0 0 8px rgba(0,229,160,0.5); }
  .ann-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
  .ann-desc  { font-size: 12px; color: var(--muted); line-height: 1.55; }

  .demo-verdict {
    margin-top: 14px; border-radius: 12px; padding: 14px 18px;
    display: flex; align-items: center; gap: 12px; border: 1px solid;
    font-family: var(--display);
  }
  .demo-verdict.dv-danger { background: var(--danger-dim); border-color: rgba(255,71,87,0.25); }
  .demo-verdict.dv-safe   { background: var(--safe-dim);   border-color: rgba(0,229,160,0.25); }
  .dv-icon {
    width: 34px; height: 34px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; flex-shrink: 0; font-family: var(--mono); font-weight: 700;
  }
  .dv-danger .dv-icon { background: rgba(255,71,87,0.15); color: var(--danger); }
  .dv-safe   .dv-icon { background: rgba(0,229,160,0.15); color: var(--safe); }
  .dv-label { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2px; }
  .dv-danger .dv-label { color: var(--danger); }
  .dv-safe   .dv-label { color: var(--safe); }
  .dv-text { font-size: 13px; color: var(--text); line-height: 1.5; }

  @media (max-width: 600px) {
    nav { padding: 14px 20px; }
    .hero { padding: 72px 20px 52px; }
    #result-section, .how-section, .demo-section { padding-left: 20px; padding-right: 20px; }
    .verdict-top { flex-direction: column; }
    .url-field { flex-wrap: wrap; }
    .check-btn { width: 100%; justify-content: center; }
  }

  /* OPEN SITE BUTTON */
  .open-site-btn {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 14px; padding: 16px 20px;
    border-radius: 14px; border: 1px solid;
    text-decoration: none; transition: all 0.18s;
    cursor: pointer;
  }
  .open-site-btn:hover { transform: translateY(-2px); }
  .open-site-btn:hover .osb-arrow { transform: translateX(4px); }
  .osb-safe   { background: var(--safe-dim);    border-color: rgba(0,229,160,0.25);  color: var(--safe); }
  .osb-danger { background: var(--danger-dim);  border-color: rgba(255,71,87,0.25);  color: var(--danger); }
  .osb-warning{ background: var(--warn-dim);    border-color: rgba(255,165,2,0.25);  color: var(--warn); }
  .osb-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .osb-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .osb-label { font-size: 13px; font-weight: 700; }
  .osb-url {
