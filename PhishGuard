<script>
function switchDemo(which, btn) {
  document.querySelectorAll('.demo-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.demo-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('demo-' + which).classList.add('active');
}

const SUSPICIOUS_TLDS = ['xyz','tk','ml','ga','cf','gq','buzz','click','link','online','site','info','top','club','pw','cc','su'];
const RISKY_TLDS = ['io','co','net'];
const KNOWN_BRANDS = {
  paypal:'paypal.com', google:'google.com', facebook:'facebook.com',
  amazon:'amazon.com', apple:'apple.com', microsoft:'microsoft.com',
  netflix:'netflix.com', instagram:'instagram.com', twitter:'twitter.com',
  youtube:'youtube.com', linkedin:'linkedin.com', github:'github.com',
  dropbox:'dropbox.com', gmail:'gmail.com', yahoo:'yahoo.com',
};
const SUSPICIOUS_KEYWORDS = ['secure','verify','login','signin','account','update','confirm','banking','wallet','support','helpdesk','service','recovery','alert','suspended','urgent','free','prize','winner','bonus'];
const SAFE_DOMAINS = ['google.com','github.com','microsoft.com','apple.com','amazon.com','facebook.com','twitter.com','linkedin.com','youtube.com','netflix.com','instagram.com','paypal.com','dropbox.com'];

function normalizeURL(raw) {
  raw = raw.trim();
  if (!raw) return null;
  if (!/^https?:\/\//i.test(raw)) raw = 'https://' + raw;
  try { return new URL(raw); } catch(e) { return null; }
}

function levenshtein(a, b) {
  const dp = Array.from({length: a.length+1}, (_,i) => [i]);
  for (let j=0; j<=b.length; j++) dp[0][j]=j;
  for (let i=1; i<=a.length; i++)
    for (let j=1; j<=b.length; j++)
      dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1] : 1+Math.min(dp[i-1][j-1],dp[i-1][j],dp[i][j-1]);
  return dp[a.length][b.length];
}

function analyze(urlObj) {
  const full = urlObj.href;
  const host = urlObj.hostname.toLowerCase().replace(/^www\./,'');
  const parts = host.split('.');
  const tld = parts[parts.length-1];
  const domain = parts.length>=2 ? parts[parts.length-2]+'.'+tld : host;
  const isHTTPS = urlObj.protocol==='https:';
  const isIP = /^\d+\.\d+\.\d+\.\d+$/.test(urlObj.hostname);
  const subdomainCount = parts.length-2;

  let score=0;
  const flags=[], positives=[], signals={};

  signals.protocol = { label:'Protocol', value:urlObj.protocol.replace(':',''), detail:isHTTPS?'Encrypted connection':'No encryption — data can be intercepted' };
  if (!isHTTPS) { score+=30; flags.push({sev:'red',text:'No HTTPS encryption',sub:'Your data can be read by anyone on the network.'}); signals.protocol.status='danger'; }
  else { positives.push('Connection is encrypted with HTTPS'); signals.protocol.status='safe'; }

  if (isIP) {
    score+=40;
    signals.host={label:'Host type',value:'IP address',detail:'Websites use IP addresses to hide domain identity',status:'danger'};
    flags.push({sev:'red',text:'IP address used instead of domain name',sub:'Legitimate websites never use raw IP addresses as their URL.'});
  } else {
    signals.host={label:'Host',value:host.length>42?host.slice(0,42)+'…':host,detail:'Domain name looks like a standard hostname',status:subdomainCount>2?'warn':'safe'};
  }

  signals.tld={label:'TLD',value:'.'+tld,detail:''};
  if (SUSPICIOUS_TLDS.includes(tld)) {
    score+=25; flags.push({sev:'red',text:`High-risk TLD: .${tld}`,sub:'Free/cheap TLDs like .xyz, .tk, .ml are widely abused for phishing.'});
    signals.tld.status='danger'; signals.tld.detail='Frequently used in scam campaigns';
  } else if (RISKY_TLDS.includes(tld)) {
    score+=8; signals.tld.status='warn'; signals.tld.detail='Slightly elevated risk TLD';
  } else { signals.tld.status='safe'; signals.tld.detail='Standard, reputable TLD'; }

  let impersonated=null;
  for (const [brand,official] of Object.entries(KNOWN_BRANDS)) {
    const od=official.replace('www.','');
    if (host.includes(brand) && !host.endsWith(od) && host!==od) {
      if (levenshtein(domain.split('.')[0],brand)<=3) { impersonated=brand; score+=35; break; }
    }
  }
  signals.brand={label:'Brand check',value:impersonated?`Impersonates ${impersonated}`:'No impersonation detected',detail:impersonated?`Uses "${impersonated}" in domain but is not the official site`:'Domain does not mimic a known brand',status:impersonated?'danger':'safe'};
  if (impersonated) flags.push({sev:'red',text:`Impersonates "${impersonated}"`,sub:`This domain contains "${impersonated}" but is not the official website.`});

  let typo=null;
  for (const [brand] of Object.entries(KNOWN_BRANDS)) {
    const dr=domain.split('.')[0], dist=levenshtein(dr,brand);
    if (dist>0 && dist<=2 && dr!==brand) { typo=brand; break; }
  }
  signals.typo={label:'Typosquatting',value:typo?`Similar to "${typo}"`:'None detected',detail:typo?`Domain is ${levenshtein(domain.split('.')[0],typo)} char(s) away from "${typo}"`:'No look-alike brand names found',status:typo?'danger':'safe'};
  if (typo && !impersonated) { score+=30; flags.push({sev:'red',text:`Possible typosquatting of "${typo}"`,sub:`Domain closely resembles "${typo}" — may be designed to trick you.`}); }

  const fullLower=full.toLowerCase();
  const foundKw=SUSPICIOUS_KEYWORDS.filter(kw=>fullLower.includes(kw));
  signals.keywords={label:'Suspicious keywords',value:foundKw.length?foundKw.slice(0,3).join(', '):'None found',detail:foundKw.length?`Found ${foundKw.length} suspicious keyword(s) in URL`:'No alarm keywords in the URL',status:foundKw.length>=3?'danger':foundKw.length>=1?'warn':'safe'};
  if (foundKw.length>=3) { score+=20; flags.push({sev:'yellow',text:`Multiple suspicious keywords: ${foundKw.slice(0,3).join(', ')}`,sub:'Phishing URLs often combine words like "secure", "verify", "login" to appear legitimate.'}); }
  else if (foundKw.length>=1) score+=8;

  signals.subdomains={label:'Subdomains',value:subdomainCount>0?subdomainCount+' subdomain(s)':'None',detail:subdomainCount>2?'Excessive subdomains can mask the real domain':'Normal subdomain usage',status:subdomainCount>2?'warn':'safe'};
  if (subdomainCount>2) { score+=15; flags.push({sev:'yellow',text:`Excessive subdomains (${subdomainCount})`,sub:'Using many subdomains can disguise the actual domain owner.'}); }

  const urlLen=full.length;
  signals.length={label:'URL length',value:urlLen+' characters',detail:urlLen>100?'Very long URLs are used to hide the real destination':'Normal URL length',status:urlLen>100?'warn':'safe'};
  if (urlLen>100) { score+=10; flags.push({sev:'yellow',text:'Very long URL',sub:'Phishing URLs are often made long to bury the real domain.'}); }

  const isTrusted=SAFE_DOMAINS.some(d=>host===d||host.endsWith('.'+d));
  if (isTrusted) { score=Math.min(score,5); positives.push('Domain is on the trusted website list'); }
  if (isHTTPS && !flags.some(f=>f.text.includes('HTTPS'))) positives.push('HTTPS encryption active');
  if (!typo && !impersonated) positives.push('Domain does not mimic any known brand');
  if (!SUSPICIOUS_TLDS.includes(tld)) positives.push(`TLD .${tld} is a reputable extension`);
  if (foundKw.length===0) positives.push('No suspicious keywords in the URL');

  return { score:Math.min(score,100), flags, positives, signals, host, domain, tld, isHTTPS, isTrusted };
}

function checkURL() {
  const input = document.getElementById('url-input');
  const raw = input.value;
  const sec = document.getElementById('result-section');

  if (!raw.trim()) { input.focus(); return; }

  input.value = '';

  sec.className = 'visible';
  sec.innerHTML = `<div class="loading-wrap"><div class="scanner-ring"></div><div class="loading-text">Scanning URL...</div><div class="loading-url">${raw}</div></div>`;
  sec.scrollIntoView({behavior:'smooth',block:'start'});

  setTimeout(() => {
    const urlObj = normalizeURL(raw);
    if (!urlObj) {
      sec.innerHTML = `<div class="error-card"><div class="err-icon">⚠️</div><p>Couldn't parse that URL.<br>Try a full address like <code>https://example.com</code></p></div>`;
      return;
    }
    renderResult(sec, analyze(urlObj), urlObj.href);
  }, 950);
}

function renderResult(sec, r, url) {
  const { score, flags, positives, signals, isTrusted } = r;
  let verdict, vClass, vIcon, vLabel;
  if (score>=50) { verdict='This looks like a phishing or scam website'; vClass='danger'; vIcon='✕'; vLabel='Dangerous'; }
  else if (score>=25) { verdict='This URL has suspicious characteristics'; vClass='warning'; vIcon='!'; vLabel='Suspicious'; }
  else { verdict=isTrusted?'This is a well-known, trusted website':'No obvious phishing signals detected'; vClass='safe'; vIcon='✓'; vLabel='Likely Safe'; }

  const riskColor = score>=50?'var(--danger)':score>=25?'var(--warn)':'var(--safe)';

  const signalCards = Object.values(signals).map(s=>`
    <div class="signal-card">
      <div class="signal-head">
        <span class="signal-name">${s.label}</span>
        <span class="signal-badge badge-${s.status||'neutral'}">${s.status||'—'}</span>
      </div>
      <div class="signal-value">${s.value}</div>
      <div class="signal-detail">${s.detail}</div>
    </div>`).join('');

  const allFlags = [
    ...flags.map(f=>`<div class="flag-item"><div class="flag-dot ${f.sev}"></div><div><div class="flag-text">${f.text}</div><div class="flag-sub">${f.sub}</div></div></div>`),
    ...positives.map(p=>`<div class="flag-item"><div class="flag-dot green"></div><div class="flag-text">${p}</div></div>`)
  ].join('');

  sec.innerHTML = `
    <div class="verdict-card ${vClass}">
      <div class="verdict-top">
        <div class="verdict-icon">${vIcon}</div>
        <div style="min-width:0">
          <div class="verdict-label">${vLabel}</div>
          <div class="verdict-title">${verdict}</div>
          <div class="verdict-url">${url}</div>
        </div>
      </div>
      <div class="risk-score">
        <span class="risk-label">Risk score</span>
        <div class="risk-track"><div class="risk-fill" id="risk-fill" style="background:${riskColor}"></div></div>
        <span class="risk-num" style="color:${riskColor}">${score}<span>/100</span></span>
      </div>
    </div>

    <div class="section-label">Signals checked</div>
    <div class="signals-grid">${signalCards}</div>

    <div class="flags-section">
      <div class="section-label">Findings</div>
      ${allFlags||'<p style="font-size:13px;color:var(--muted)">Nothing suspicious to report.</p>'}
    </div>

    <div class="tips-box">
      <div class="section-label">How to stay safe</div>
      <div class="tip-row"><div class="tip-num">1</div><div class="tip-text"><strong>Always check the domain carefully.</strong> Phishers use look-alike domains (paypa1.com, g00gle.com) to trick you at a glance.</div></div>
      <div class="tip-row"><div class="tip-num">2</div><div class="tip-text"><strong>Look for HTTPS + the padlock.</strong> Encrypted connections protect your data. HTTP means anyone can see what you send.</div></div>
      <div class="tip-row"><div class="tip-num">3</div><div class="tip-text"><strong>Never click login links in emails.</strong> Always type the official URL directly into your browser address bar.</div></div>
      <div class="tip-row"><div class="tip-num">4</div><div class="tip-text"><strong>Urgency is a manipulation tactic.</strong> Real companies don't threaten to delete your account immediately.</div></div>
    </div>

    <a href="${url}" target="_blank" rel="noopener noreferrer" class="open-site-btn osb-${vClass}">
      <span class="osb-left">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
          <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M7.5 1C7.5 1 5.5 4 5.5 7.5C5.5 11 7.5 14 7.5 14" stroke="currentColor" stroke-width="1.2"/>
          <path d="M7.5 1C7.5 1 9.5 4 9.5 7.5C9.5 11 7.5 14 7.5 14" stroke="currentColor" stroke-width="1.2"/>
          <path d="M1 7.5H14" stroke="currentColor" stroke-width="1.2"/>
        </svg>
        <span class="osb-text">
          <span class="osb-label">Open this website</span>
          <span class="osb-url">${url}</span>
        </span>
      </span>
      <svg class="osb-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8H13M9 4L13 8L9 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    ${score>=50 ? '<p class="open-warning open-warning-danger">&#9888; This site was flagged as dangerous. Proceed only if you know what you are doing.</p>' : score>=25 ? '<p class="open-warning open-warning-warn">&#9888; This site has suspicious signals. Be cautious before entering any information.</p>' : ''}
  `;

  setTimeout(() => {
    const fill = document.getElementById('risk-fill');
    if (fill) fill.style.width = score + '%';
  }, 60);
}
</script>
